<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:AuraEcho.Design.AttachedProperties">

    <Style x:Key="NoAppearanceTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"
                                      IsTabStop="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="PasswordToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Padding" Value="5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ui:ControlHelper.CornerRadius" Value="2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="LayoutRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            ClipToBounds="{TemplateBinding ClipToBounds}"
                            CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                            TextBlock.Foreground="{TemplateBinding Foreground}"
                            UseLayoutRounding="{TemplateBinding UseLayoutRounding}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="LayoutRoot"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{DynamicResource Colors.Overlay.Level4}"
                                                        Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="LayoutRoot"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{DynamicResource Colors.Overlay.Level3}"
                                                        Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- 浮动标签 PasswordBox 模板 -->
    <ControlTemplate x:Key="FloatingLabelPasswordBoxTemplate" TargetType="{x:Type PasswordBox}">
        <ControlTemplate.Resources>
            <Storyboard x:Key="PlaceholderToUp">
                <DoubleAnimation Storyboard.TargetName="PlaceHolderScaleTransform"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="0.75"
                                 Duration="0:0:0.1">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PlaceHolderScaleTransform"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="0.75"
                                 Duration="0:0:0.1">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PlaceHolderTranslateTransform"
                                 Storyboard.TargetProperty="Y"
                                 To="-20"
                                 Duration="0:0:0.1">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PlaceHolderBackground"
                                 Storyboard.TargetProperty="Opacity"
                                 To="1"
                                 Duration="0:0:0.1" />
            </Storyboard>
            <Storyboard x:Key="PlaceholderToDown">
                <DoubleAnimation Storyboard.TargetName="PlaceHolderScaleTransform"
                                 Storyboard.TargetProperty="ScaleX"
                                 To="1"
                                 Duration="0:0:0.1">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PlaceHolderScaleTransform"
                                 Storyboard.TargetProperty="ScaleY"
                                 To="1"
                                 Duration="0:0:0.1">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PlaceHolderTranslateTransform"
                                 Storyboard.TargetProperty="Y"
                                 To="0"
                                 Duration="0:0:0.1">
                    <DoubleAnimation.EasingFunction>
                        <CircleEase EasingMode="EaseOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PlaceHolderBackground"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0"
                                 Duration="0:0:0.1" />
            </Storyboard>
        </ControlTemplate.Resources>
        <Grid>
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ScrollViewer x:Name="PART_ContentHost"
                              VerticalAlignment="Center"
                              IsTabStop="False"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Hidden" />
                <TextBox x:Name="PlainTextBox"
                         Grid.Column="0"
                         Padding="{TemplateBinding Padding}"
                         ui:ControlHelper.CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                         BorderThickness="0"
                         CaretBrush="{TemplateBinding CaretBrush}"
                         Foreground="{TemplateBinding Foreground}"
                         InputMethod.IsInputMethodEnabled="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(InputMethod.IsInputMethodEnabled)}"
                         MaxLength="{TemplateBinding MaxLength}"
                         SelectionBrush="{TemplateBinding SelectionBrush}"
                         Style="{StaticResource NoAppearanceTextBox}"
                         Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:PasswordBoxHelper.Password), Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="Hidden" />
                <Grid Margin="{TemplateBinding Padding}"
                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                      IsHitTestVisible="False"
                      RenderTransformOrigin="0, 0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="PlaceHolderScaleTransform" />
                            <TranslateTransform x:Name="PlaceHolderTranslateTransform" Y="0" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Border x:Name="PlaceHolderBackground"
                            Background="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:InputBoxHelper.FloatingBackground)}"
                            Opacity="0" />
                    <TextBlock x:Name="PlaceHolderTextBlock"
                               Padding="3, 0"
                               Background="Transparent"
                               FontSize="{TemplateBinding FontSize}"
                               Foreground="{DynamicResource Brushes.OnSurfaceVariant}"
                               Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.PlaceHolder)}" />
                </Grid>
                <ToggleButton x:Name="SwitchButton"
                              Grid.Column="1"
                              Margin="0,0,6,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Focusable="False"
                              IsTabStop="False"
                              Style="{StaticResource PasswordToggleButtonStyle}">
                    <Canvas x:Name="SwitchButtonIcon"
                            Width="16.0"
                            Height="16.0"
                            UseLayoutRounding="True">
                        <Path Data="M 14.98 7.83 C 14.99 7.84 15 7.91 15 8 C 15 8.09 14.99 8.16 14.98 8.21 L 14.98 8.21 L 14.98 8.21 C 14.98 8.21 14.98 8.27 14.95 8.34 C 14.95 8.35 14.95 8.36 14.94 8.37 C 14.93 8.4 14.92 8.43 14.9 8.47 C 13.63 11.47 10.85 13.5 8 13.5 C 5.16 13.5 2.38 11.47 1.08 8.44 C 1.08 8.42 1.07 8.4 1.06 8.38 C 1.05 8.35 1.04 8.31 1.03 8.28 H 1.03 C 1.03 8.24 1.02 8.2 1.02 8.17 C 1.01 8.15 1 8.05 1 8.05 C 1 8.02 1 7.99 1 7.95 C 1 7.95 1.01 7.84 1.03 7.78 C 1.02 7.79 1.02 7.74 1.05 7.66 C 1.05 7.65 1.05 7.65 1.05 7.65 C 1.05 7.64 1.06 7.64 1.06 7.63 C 1.07 7.6 1.08 7.57 1.09 7.54 C 2.38 4.53 5.16 2.5 8 2.5 C 10.85 2.5 13.62 4.53 14.92 7.56 C 14.92 7.58 14.93 7.6 14.94 7.63 C 14.94 7.63 14.94 7.63 14.94 7.64 C 14.95 7.64 14.95 7.65 14.95 7.66 C 14.96 7.7 14.98 7.78 14.98 7.83 Z M 14.05 8.05 C 14.06 8.04 14.06 8.04 14.06 8.04 C 14.06 8.03 14.06 8.02 14.06 8.01 C 14.06 8 14.06 7.99 14.06 7.97 C 14.06 7.97 14.06 7.96 14.06 7.96 C 14.05 7.95 14.05 7.95 14.05 7.95 L 14.05 7.95 C 14.05 7.94 14.05 7.94 14.05 7.93 C 12.9 5.28 10.48 3.5 8 3.5 C 5.53 3.5 3.1 5.28 1.95 7.94 C 1.95 7.94 1.95 7.94 1.95 7.95 C 1.94 7.95 1.94 7.95 1.94 7.95 C 1.94 7.97 1.94 7.98 1.94 7.99 V 8 C 1.94 8 1.94 8.01 1.94 8.02 C 1.94 8.02 1.94 8.02 1.94 8.02 C 1.94 8.03 1.94 8.03 1.94 8.04 C 1.94 8.04 1.95 8.05 1.95 8.05 C 1.95 8.06 1.95 8.06 1.95 8.06 C 3.11 10.72 5.53 12.5 8 12.5 C 10.48 12.5 12.9 10.72 14.05 8.07 C 14.05 8.06 14.05 8.06 14.05 8.05 C 14.05 8.05 14.05 8.05 14.05 8.05 Z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}" />
                        <Ellipse Canvas.Left="5.0"
                                 Canvas.Top="5.0"
                                 Width="6.0"
                                 Height="6.0"
                                 Stroke="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}"
                                 StrokeDashCap="Flat"
                                 StrokeThickness="1.0" />
                        <Path x:Name="HiddenLine"
                              Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}"
                              StrokeDashCap="Flat"
                              StrokeThickness="0.5"
                              Visibility="Hidden">
                            <Path.Data>
                                <PathGeometry Figures="M 2.91 1.89 L 2.9 1.89 L 2.89 1.88 C 2.61 1.68 2.22 1.71 1.97 1.96 C 1.68 2.24 1.68 2.7 1.96 2.98 L 13.01 14.04 L 13.01 14.04 L 13.02 14.05 L 13.09 14.11 L 13.1 14.11 L 13.11 14.12 C 13.39 14.32 13.78 14.29 14.03 14.04 C 14.32 13.76 14.32 13.3 14.04 13.02 L 2.99 1.96 L 2.99 1.96 L 2.98 1.95 L 2.91 1.89 Z" FillRule="Nonzero" />
                            </Path.Data>
                        </Path>
                    </Canvas>
                </ToggleButton>
            </Grid>
        </Grid>
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=(ui:PasswordBoxHelper.PasswordLength)}" Value="0">
                <Setter TargetName="SwitchButton" Property="Visibility" Value="Hidden" />
            </DataTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition SourceName="PlainTextBox" Property="IsFocused" Value="False" />
                    <Condition Property="IsFocused" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="SwitchButton" Property="Visibility" Value="Hidden" />
            </MultiTrigger>
            <Trigger SourceName="SwitchButton" Property="IsChecked" Value="True">
                <Setter TargetName="PlainTextBox" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_ContentHost" Property="Visibility" Value="Hidden" />
                <Setter TargetName="HiddenLine" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brushes.OnSurface}" />
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard Storyboard="{StaticResource PlaceholderToUp}" />
                </Trigger.EnterActions>
                <Setter TargetName="border" Property="BorderThickness" Value="2" />
                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brushes.Primary}" />
                <Setter TargetName="PlaceHolderTextBlock" Property="Foreground" Value="{DynamicResource Brushes.Primary}" />
            </Trigger>
            <Trigger SourceName="PlainTextBox" Property="IsFocused" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard Storyboard="{StaticResource PlaceholderToUp}" />
                </Trigger.EnterActions>
                <Setter TargetName="border" Property="BorderThickness" Value="2" />
                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brushes.Primary}" />
                <Setter TargetName="PlaceHolderTextBlock" Property="Foreground" Value="{DynamicResource Brushes.Primary}" />
            </Trigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsFocused}" Value="False" />
                    <Condition Binding="{Binding ElementName=PlainTextBox, Path=IsFocused}" Value="False" />
                    <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=(ui:PasswordBoxHelper.PasswordLength)}" Value="0" />
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard Storyboard="{StaticResource PlaceholderToDown}" />
                </MultiDataTrigger.EnterActions>
                <MultiDataTrigger.ExitActions>
                    <BeginStoryboard Storyboard="{StaticResource PlaceholderToUp}" />
                </MultiDataTrigger.ExitActions>
            </MultiDataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ValidationErrorTemplate">
        <DockPanel IsHitTestVisible="False" LastChildFill="True">
            <TextBlock Margin="0,4,0,0"
                       DockPanel.Dock="Bottom"
                       FontSize="12"
                       Foreground="{DynamicResource Brushes.Error}"
                       Text="{Binding [0].ErrorContent}" />
            <AdornedElementPlaceholder />
        </DockPanel>
    </ControlTemplate>

    <!-- 浮动水印 Password 样式 -->
    <Style x:Key="FloatingLabelPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Outline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brushes.Primary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="PasswordChar" Value="●" />
        <Setter Property="ui:ControlHelper.CornerRadius" Value="2" />
        <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
        <Setter Property="ui:PasswordBoxHelper.Attach" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ContextMenu" Value="{DynamicResource TextEditingContextMenu}" />
        <Setter Property="Template" Value="{StaticResource FloatingLabelPasswordBoxTemplate}" />
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Error}" />
                <Setter Property="BorderThickness" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- PasswordBox 模板 -->
    <ControlTemplate x:Key="RegularPasswordBoxTemplate" TargetType="{x:Type PasswordBox}">
        <Grid>
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                    SnapsToDevicePixels="True" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ScrollViewer x:Name="PART_ContentHost"
                              VerticalAlignment="Center"
                              Focusable="False"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Hidden" />
                <TextBox x:Name="PlainTextBox"
                         Grid.Column="0"
                         Padding="{TemplateBinding Padding}"
                         ui:ControlHelper.CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                         BorderThickness="0"
                         CaretBrush="{TemplateBinding CaretBrush}"
                         Foreground="{TemplateBinding Foreground}"
                         InputMethod.IsInputMethodEnabled="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(InputMethod.IsInputMethodEnabled)}"
                         MaxLength="{TemplateBinding MaxLength}"
                         SelectionBrush="{TemplateBinding SelectionBrush}"
                         Style="{StaticResource NoAppearanceTextBox}"
                         Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:PasswordBoxHelper.Password), Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="Hidden" />
                <TextBlock x:Name="PlaceHolderTextBlock"
                           Margin="{TemplateBinding Padding}"
                           Padding="2,0,0,0"
                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                           Focusable="False"
                           FontSize="{TemplateBinding FontSize}"
                           Foreground="{DynamicResource Brushes.OnSurfaceVariant}"
                           IsHitTestVisible="False"
                           Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.PlaceHolder)}"
                           Visibility="Hidden" />
                <ToggleButton x:Name="SwitchButton"
                              Grid.Column="1"
                              Margin="0,0,6,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Focusable="False"
                              IsTabStop="False"
                              Style="{StaticResource PasswordToggleButtonStyle}">
                    <Canvas x:Name="SwitchButtonIcon"
                            Width="16.0"
                            Height="16.0"
                            UseLayoutRounding="True">
                        <Path Data="M 14.98 7.83 C 14.99 7.84 15 7.91 15 8 C 15 8.09 14.99 8.16 14.98 8.21 L 14.98 8.21 L 14.98 8.21 C 14.98 8.21 14.98 8.27 14.95 8.34 C 14.95 8.35 14.95 8.36 14.94 8.37 C 14.93 8.4 14.92 8.43 14.9 8.47 C 13.63 11.47 10.85 13.5 8 13.5 C 5.16 13.5 2.38 11.47 1.08 8.44 C 1.08 8.42 1.07 8.4 1.06 8.38 C 1.05 8.35 1.04 8.31 1.03 8.28 H 1.03 C 1.03 8.24 1.02 8.2 1.02 8.17 C 1.01 8.15 1 8.05 1 8.05 C 1 8.02 1 7.99 1 7.95 C 1 7.95 1.01 7.84 1.03 7.78 C 1.02 7.79 1.02 7.74 1.05 7.66 C 1.05 7.65 1.05 7.65 1.05 7.65 C 1.05 7.64 1.06 7.64 1.06 7.63 C 1.07 7.6 1.08 7.57 1.09 7.54 C 2.38 4.53 5.16 2.5 8 2.5 C 10.85 2.5 13.62 4.53 14.92 7.56 C 14.92 7.58 14.93 7.6 14.94 7.63 C 14.94 7.63 14.94 7.63 14.94 7.64 C 14.95 7.64 14.95 7.65 14.95 7.66 C 14.96 7.7 14.98 7.78 14.98 7.83 Z M 14.05 8.05 C 14.06 8.04 14.06 8.04 14.06 8.04 C 14.06 8.03 14.06 8.02 14.06 8.01 C 14.06 8 14.06 7.99 14.06 7.97 C 14.06 7.97 14.06 7.96 14.06 7.96 C 14.05 7.95 14.05 7.95 14.05 7.95 L 14.05 7.95 C 14.05 7.94 14.05 7.94 14.05 7.93 C 12.9 5.28 10.48 3.5 8 3.5 C 5.53 3.5 3.1 5.28 1.95 7.94 C 1.95 7.94 1.95 7.94 1.95 7.95 C 1.94 7.95 1.94 7.95 1.94 7.95 C 1.94 7.97 1.94 7.98 1.94 7.99 V 8 C 1.94 8 1.94 8.01 1.94 8.02 C 1.94 8.02 1.94 8.02 1.94 8.02 C 1.94 8.03 1.94 8.03 1.94 8.04 C 1.94 8.04 1.95 8.05 1.95 8.05 C 1.95 8.06 1.95 8.06 1.95 8.06 C 3.11 10.72 5.53 12.5 8 12.5 C 10.48 12.5 12.9 10.72 14.05 8.07 C 14.05 8.06 14.05 8.06 14.05 8.05 C 14.05 8.05 14.05 8.05 14.05 8.05 Z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}" />
                        <Ellipse Canvas.Left="5.0"
                                 Canvas.Top="5.0"
                                 Width="6.0"
                                 Height="6.0"
                                 Stroke="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}"
                                 StrokeDashCap="Flat"
                                 StrokeThickness="1.0" />
                        <Path x:Name="HiddenLine"
                              Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}"
                              StrokeDashCap="Flat"
                              StrokeThickness="0.5"
                              Visibility="Hidden">
                            <Path.Data>
                                <PathGeometry Figures="M 2.91 1.89 L 2.9 1.89 L 2.89 1.88 C 2.61 1.68 2.22 1.71 1.97 1.96 C 1.68 2.24 1.68 2.7 1.96 2.98 L 13.01 14.04 L 13.01 14.04 L 13.02 14.05 L 13.09 14.11 L 13.1 14.11 L 13.11 14.12 C 13.39 14.32 13.78 14.29 14.03 14.04 C 14.32 13.76 14.32 13.3 14.04 13.02 L 2.99 1.96 L 2.99 1.96 L 2.98 1.95 L 2.91 1.89 Z" FillRule="Nonzero" />
                            </Path.Data>
                        </Path>
                    </Canvas>
                </ToggleButton>
            </Grid>
        </Grid>
        <ControlTemplate.Triggers>

            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=(ui:PasswordBoxHelper.PasswordLength)}" Value="0">
                <Setter TargetName="PlaceHolderTextBlock" Property="Visibility" Value="Visible" />
                <Setter TargetName="SwitchButton" Property="Visibility" Value="Hidden" />
            </DataTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition SourceName="PlainTextBox" Property="IsFocused" Value="False" />
                    <Condition Property="IsFocused" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="SwitchButton" Property="Visibility" Value="Hidden" />
            </MultiTrigger>
            <Trigger SourceName="SwitchButton" Property="IsChecked" Value="True">
                <Setter TargetName="PlainTextBox" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_ContentHost" Property="Visibility" Value="Hidden" />
                <Setter TargetName="HiddenLine" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brushes.OnSurface}" />
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="border" Property="BorderThickness" Value="2" />
                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brushes.Primary}" />
            </Trigger>
            <Trigger SourceName="PlainTextBox" Property="IsFocused" Value="True">
                <Setter TargetName="border" Property="BorderThickness" Value="2" />
                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brushes.Primary}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- 常规 Password 样式 -->
    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Outline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brushes.Primary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="PasswordChar" Value="●" />
        <Setter Property="ui:ControlHelper.CornerRadius" Value="2" />
        <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
        <Setter Property="ui:PasswordBoxHelper.Attach" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ContextMenu" Value="{DynamicResource TextEditingContextMenu}" />
        <Setter Property="Template" Value="{StaticResource RegularPasswordBoxTemplate}" />
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Error}" />
                <Setter Property="BorderThickness" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>