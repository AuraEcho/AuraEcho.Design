<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Display -->
    <sys:Double x:Key="FontSize.Display.Large">64</sys:Double>
    <sys:Double x:Key="FontSize.Display.Medium">48</sys:Double>
    <sys:Double x:Key="FontSize.Display.Small">32</sys:Double>
    <!-- Headline -->
    <sys:Double x:Key="FontSize.Headline.Large">32</sys:Double>
    <sys:Double x:Key="FontSize.Headline.Medium">28</sys:Double>
    <sys:Double x:Key="FontSize.Headline.Small">24</sys:Double>
    <!-- Title -->
    <sys:Double x:Key="FontSize.Title.Large">20</sys:Double>
    <sys:Double x:Key="FontSize.Title.Medium">18</sys:Double>
    <sys:Double x:Key="FontSize.Title.Small">16</sys:Double>
    <!-- Body -->
    <sys:Double x:Key="FontSize.Body.Large">16</sys:Double>
    <sys:Double x:Key="FontSize.Body.Medium">14</sys:Double>
    <sys:Double x:Key="FontSize.Body.Small">12</sys:Double>
    <!-- Label -->
    <sys:Double x:Key="FontSize.Label.Large">16</sys:Double>
    <sys:Double x:Key="FontSize.Label.Medium">14</sys:Double>
    <sys:Double x:Key="FontSize.Label.Small">12</sys:Double>

</ResourceDictionary>