    <!-- 主色（品牌色），用于按钮、强调元素 -->
    <SolidColorBrush x:Key="Brushes.Primary" Color="{StaticResource Colors.Primary-45}" />
    <!-- 主色上的前景色（文字/图标），保证对比度 -->
    <SolidColorBrush x:Key="Brushes.OnPrimary" Color="{StaticResource Colors.Primary-100}" />
    <!-- 主色容器（较浅背景），用于卡片/块状区域 -->
    <SolidColorBrush x:Key="Brushes.PrimaryContainer" Color="{StaticResource Colors.Primary-90}" />
    <!-- 主色容器上的内容颜色 -->
    <SolidColorBrush x:Key="Brushes.OnPrimaryContainer" Color="{StaticResource Colors.Primary-30}" />

    <!-- 次要色，用于辅助强调 -->
    <SolidColorBrush x:Key="Brushes.Secondary" Color="{StaticResource Colors.Secondary-40}" />
    <!-- 次要色上的内容颜色 -->
    <SolidColorBrush x:Key="Brushes.OnSecondary" Color="{StaticResource Colors.Secondary-100}" />
    <!-- 次要色容器背景 -->
    <SolidColorBrush x:Key="Brushes.SecondaryContainer" Color="{StaticResource Colors.Secondary-90}" />
    <!-- 次要容器上的内容颜色 -->
    <SolidColorBrush x:Key="Brushes.OnSecondaryContainer" Color="{StaticResource Colors.Secondary-30}" />

    <!-- 第三级强调色（用于区分不同类型信息） -->
    <SolidColorBrush x:Key="Brushes.Tertiary" Color="{StaticResource Colors.Tertiary-40}" />
    <!-- 第三级强调色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiary" Color="{StaticResource Colors.Tertiary-100}" />
    <!-- 第三级容器背景 -->
    <SolidColorBrush x:Key="Brushes.TertiaryContainer" Color="{StaticResource Colors.Tertiary-90}" />
    <!-- 第三级容器上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiaryContainer" Color="{StaticResource Colors.Tertiary-30}" />

    <!-- 错误色（警告/错误提示） -->
    <SolidColorBrush x:Key="Brushes.Error" Color="{StaticResource Colors.Error-40}" />
    <!-- 错误色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnError" Color="{StaticResource Colors.Error-100}" />
    <!-- 错误背景（浅色提示框） -->
    <SolidColorBrush x:Key="Brushes.ErrorContainer" Color="{StaticResource Colors.Error-90}" />
    <!-- 错误背景上的文字 -->
    <SolidColorBrush x:Key="Brushes.OnErrorContainer" Color="{StaticResource Colors.Error-30}" />

    <!-- 应用整体背景 -->
    <!--<SolidColorBrush x:Key="Brushes.Background" Color="{StaticResource Colors.Neutral-98}" />-->
    <!-- 背景上的默认文本颜色 -->
    <!--<SolidColorBrush x:Key="Brushes.OnBackground" Color="{StaticResource Colors.Neutral-10}" />-->
    <!-- 表面颜色（卡片/面板） -->
    <!--<SolidColorBrush x:Key="Brushes.Surface" Color="{StaticResource Colors.Neutral-99}" />-->
    <!-- 表面上的内容颜色 -->
    <SolidColorBrush x:Key="Brushes.OnSurface" Color="{StaticResource Colors.Neutral-10}" />

    <!-- 表面变体（用于分层） -->
    <!--<SolidColorBrush x:Key="Brushes.SurfaceVariant" Color="{StaticResource Colors.Neutral-variant-90}" />-->
    <!-- 表面变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSurfaceVariant" Color="{StaticResource Colors.Neutral-40}" />
    <!-- 轮廓线（边框） -->
    <SolidColorBrush x:Key="Brushes.Outline" Color="{StaticResource Colors.Neutral-variant-50}" />
    <!-- 弱化轮廓线 -->
    <SolidColorBrush x:Key="Brushes.OutlineVariant" Color="{StaticResource Colors.Overlay.Level3}" />
    <SolidColorBrush x:Key="Brushes.OutlineInner" Color="{StaticResource Colors.Overlay.Level3}" />
    <SolidColorBrush x:Key="Brushes.OutlineShadow" Color="{StaticResource Colors.Overlay.Level3}" />

    <!-- 较暗的表面（用于层级） -->
    <SolidColorBrush x:Key="Brushes.SurfaceDim" Color="{StaticResource Colors.Neutral-90}" />
    <!-- 较亮的表面 -->
    <SolidColorBrush x:Key="Brushes.SurfaceBright" Color="{StaticResource Colors.Neutral-98}" />
    <!-- 最低层容器（最接近背景） -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerLowest" Color="{StaticResource Colors.Neutral-95}" />
    <!-- 低层容器 -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerLow" Color="{StaticResource Colors.Neutral-95}" />
    <!-- 默认容器 -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainer" Color="{StaticResource Colors.Neutral-99}" />
    <!-- 高层容器 -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerHigh" Color="{StaticResource Colors.Neutral-99}" />
    <!-- 最高层容器（强调层） -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerHighest" Color="{StaticResource Colors.Neutral-98}" />
    <!-- 弹窗遮罩 -->
    <SolidColorBrush x:Key="Brushes.Scrim" Color="{StaticResource Colors.White-35}" />
    <!-- 阴影 -->
    <SolidColorBrush x:Key="Brushes.Shadow" Color="{StaticResource Colors.Neutral-20}" />

    <!-- 反色表面（用于深色模式或反转区域） -->
    <SolidColorBrush x:Key="Brushes.InverseSurface" Color="{StaticResource Colors.Neutral-20}" />
    <!-- 反色表面上的内容 -->
    <SolidColorBrush x:Key="Brushes.InverseOnSurface" Color="{StaticResource Colors.Neutral-95}" />
    <!-- 反色主色（强调） -->
    <SolidColorBrush x:Key="Brushes.InversePrimary" Color="{StaticResource Colors.Primary-80}" />

    <!-- 固定主色（不随主题变化） -->
    <SolidColorBrush x:Key="Brushes.PrimaryFixed" Color="{StaticResource Colors.Primary-90}" />
    <!-- 固定主色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnPrimaryFixed" Color="{StaticResource Colors.Primary-10}" />
    <!-- 固定主色（较深版本） -->
    <SolidColorBrush x:Key="Brushes.PrimaryFixedDim" Color="{StaticResource Colors.Primary-80}" />
    <!-- 固定主色变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnPrimaryFixedVariant" Color="{StaticResource Colors.Primary-30}" />

    <!-- 固定次要色 -->
    <SolidColorBrush x:Key="Brushes.SecondaryFixed" Color="{StaticResource Colors.Secondary-90}" />
    <!-- 固定次要色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSecondaryFixed" Color="{StaticResource Colors.Secondary-10}" />
    <!-- 固定次要色（深） -->
    <SolidColorBrush x:Key="Brushes.SecondaryFixedDim" Color="{StaticResource Colors.Secondary-80}" />
    <!-- 固定次要色变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSecondaryFixedVariant" Color="{StaticResource Colors.Secondary-30}" />

    <!-- 固定第三级色 -->
    <SolidColorBrush x:Key="Brushes.TertiaryFixed" Color="{StaticResource Colors.Tertiary-90}" />
    <!-- 固定第三级色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiaryFixed" Color="{StaticResource Colors.Tertiary-10}" />
    <!-- 固定第三级色（深） -->
    <SolidColorBrush x:Key="Brushes.TertiaryFixedDim" Color="{StaticResource Colors.Tertiary-80}" />
    <!-- 固定第三级色变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiaryFixedVariant" Color="{StaticResource Colors.Tertiary-30}" />

    <SolidColorBrush x:Key="Brushes.Success" Color="#009D05" />
    <SolidColorBrush x:Key="Brushes.Warning" Color="#FF9D00" />

    <!--#region Special-->
    <!-- 背景 -->
    <LinearGradientBrush x:Key="Brushes.Special.Background" StartPoint="0, 0" EndPoint="0, 1">
        <GradientStop Offset="0" Color="#DED5FF" />
        <GradientStop Offset="1" Color="#FAF8FF" />
    </LinearGradientBrush>
    <!-- 高光边框 -->
    <DrawingBrush x:Key="Brushes.Special.HighlightOutline">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#33FFFFFF" Geometry="M0,0 H1 V1 H0 Z" />
                <GeometryDrawing Geometry="M0,0 H1 V1 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0.7, 0" EndPoint="0.5, 0.4">
                            <GradientStop Offset="0" Color="#99FFFFFF" />
                            <GradientStop Offset="1" Color="#00FFFFFF" />
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <SolidColorBrush x:Key="Brushes.Special.OnSpecialBackground" Color="{StaticResource Colors.Neutral-99}" />
    <!-- 面板上的渐变文本 -->
    <SolidColorBrush x:Key="Brushes.Special.OnSurfaceLinear" Color="{StaticResource Colors.Neutral-10}" />

    <SolidColorBrush x:Key="Brushes.Special.FloatingBackground" Color="{StaticResource Colors.Neutral-99}" />
    <!--#endregion-->

    <!-- 骨架屏 -->
    <Color x:Key="Colors.SkeletonShimmer">#66FFFFFF</Color>
    <SolidColorBrush x:Key="Brushes.SkeletonBase" Color="{StaticResource Colors.Neutral-90}" />
</ResourceDictionary>