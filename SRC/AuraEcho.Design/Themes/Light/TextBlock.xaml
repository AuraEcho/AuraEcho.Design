<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Display -->
    <Style x:Key="DisplayLargeTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Display.Large}" />
        <!--<Setter Property="LineHeight" Value="72" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="DisplayMediumTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Display.Medium}" />
        <!--<Setter Property="LineHeight" Value="56" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="DisplaySmallTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Display.Small}" />
        <!--<Setter Property="LineHeight" Value="40" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Headline -->
    <Style x:Key="HeadlineLargeTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Headline.Large}" />
        <!--<Setter Property="LineHeight" Value="40" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="HeadlineMediumTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Headline.Medium}" />
        <!--<Setter Property="LineHeight" Value="36" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="HeadlineSmallTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Headline.Small}" />
        <!--<Setter Property="LineHeight" Value="32" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <!-- Title -->
    <Style x:Key="TitleLargeTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Title.Large}" />
        <!--<Setter Property="LineHeight" Value="28" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="TitleMediumTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Title.Medium}" />
        <!--<Setter Property="LineHeight" Value="24" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="TitleSmallTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Title.Small}" />
        <!--<Setter Property="LineHeight" Value="20" />-->
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <!-- Body -->
    <Style x:Key="BodyLargeTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Large}" />
        <!--<Setter Property="LineHeight" Value="24" />-->
    </Style>
    <Style x:Key="BodyMediumTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Medium}" />
        <!--<Setter Property="LineHeight" Value="20" />-->
    </Style>
    <Style x:Key="BodySmallTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Body.Small}" />
        <!--<Setter Property="LineHeight" Value="16" />-->
    </Style>
    <!-- Label -->
    <Style x:Key="LabelLargeTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Label.Large}" />
        <!--<Setter Property="LineHeight" Value="20" />-->
    </Style>
    <Style x:Key="LabelMediumTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Label.Medium}" />
        <!--<Setter Property="LineHeight" Value="16" />-->
    </Style>
    <Style x:Key="LabelSmallTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize.Label.Small}" />
        <!--<Setter Property="LineHeight" Value="16" />-->
    </Style>
</ResourceDictionary>