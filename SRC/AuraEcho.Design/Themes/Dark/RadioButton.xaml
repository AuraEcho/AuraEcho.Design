<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:AuraEcho.Design.AttachedProperties">

    <!-- 文本单选框模板 -->
    <ControlTemplate x:Key="TextRadioButtonTemplate" TargetType="{x:Type RadioButton}">
        <Grid Background="Transparent">
            <ContentPresenter Grid.Column="1"
                              Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                              UseLayoutRounding="{TemplateBinding UseLayoutRounding}" />
        </Grid>
    </ControlTemplate>
    <!-- 文本单选框样式 -->
    <Style x:Key="TextRadioButtonStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Template" Value="{StaticResource TextRadioButtonTemplate}" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurfaceVariant}" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
                <Setter Property="FontWeight" Value="Bold" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Outline}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">

                    <BulletDecorator Background="Transparent">
                        <BulletDecorator.Bullet>
                            <Border x:Name="RootBorder"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,4,0"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <Ellipse x:Name="InnerCircle"
                                         Width="10"
                                         Height="10"
                                         Fill="{DynamicResource Brushes.Primary}"
                                         Visibility="Hidden" />
                            </Border>
                        </BulletDecorator.Bullet>
                        <ContentPresenter Margin="4,0,0,0"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </BulletDecorator>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible" />
                            <Setter TargetName="InnerCircle" Property="Fill" Value="{DynamicResource Brushes.Primary}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Primary}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RootBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level3}" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                        <!--<MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="BorderBrush" Value="{DynamicResource Brushes.PrimaryVariant}" />
                            <Setter TargetName="InnerCircle" Property="Fill" Value="{DynamicResource Brushes.PrimaryVariant}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="BorderBrush" Value="{DynamicResource Brushes.PrimaryDim}" />
                            <Setter TargetName="InnerCircle" Property="Fill" Value="{DynamicResource Brushes.PrimaryDim}" />
                            <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RootBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.White-10}" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="InnerCircle" Property="Fill" Value="{DynamicResource Brushes.PrimaryDim}" />
                            <Setter TargetName="InnerCircle" Property="Visibility" Value="Hidden" />
                        </MultiTrigger>-->
                        <Trigger Property="IsEnabled" Value="False">
                            <!--<Setter TargetName="RootBorder" Property="BorderBrush" Value="#49454E" />-->
                            <!--<Setter TargetName="InnerCircle" Property="Fill" Value="#49454E" />-->
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavigationRadioButtonStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Padding" Value="5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ui:ControlHelper.CornerRadius" Value="4" />
        <Setter Property="Background" Value="#00000000" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="LayoutRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}">
                        <Grid>
                            <Border x:Name="StateLayer"
                                    Background="Transparent"
                                    CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Focusable="False" />
                            <Line x:Name="FocusedLine"
                                  Margin="0,8"
                                  HorizontalAlignment="Left"
                                  Stretch="Fill"
                                  Stroke="{DynamicResource Brushes.Primary}"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="4"
                                  UseLayoutRounding="True"
                                  Visibility="Hidden"
                                  X1="0"
                                  X2="0"
                                  Y1="0"
                                  Y2="1" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="StateLayer" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level3}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="StateLayer" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level2}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="StateLayer" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level2}" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="FocusedLine" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsPressed" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="StateLayer" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level3}" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="FocusedLine" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardRadioButtonStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="BorderBrush" Value="{DynamicResource Brushes.OutlineVariant}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ui:ControlHelper.CornerRadius" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="LayoutRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}">
                        <Grid>
                            <Border x:Name="StateLayer"
                                    Background="{DynamicResource Brushes.Primary}"
                                    CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                                    Opacity="0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Focusable="False" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Outline}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brushes.Primary}"></Setter>
                            <Setter TargetName="StateLayer" Property="Opacity" Value="0.1"/>
                            <Setter Property="BorderThickness" Value="2" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brushes.Primary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>