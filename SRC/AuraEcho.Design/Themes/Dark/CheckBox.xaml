<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="ShowInnerShape">
                            <DoubleAnimation FillBehavior="HoldEnd"
                                             Storyboard.TargetName="InnerShape"
                                             Storyboard.TargetProperty="StrokeDashOffset"
                                             From="24"
                                             To="0"
                                             Duration="0:0:0.4" />
                        </Storyboard>
                        <Storyboard x:Key="HideInnerShape">
                            <DoubleAnimation FillBehavior="HoldEnd"
                                             Storyboard.TargetName="InnerShape"
                                             Storyboard.TargetProperty="StrokeDashOffset"
                                             To="-24"
                                             Duration="0:0:0.3" />
                        </Storyboard>
                    </ControlTemplate.Resources>

                    <BulletDecorator Background="Transparent">
                        <BulletDecorator.Bullet>
                            <Grid Width="20"
                                  Height="20"
                                  Margin="0,0,4,0">
                                <Rectangle x:Name="OuterCircle"
                                           Fill="Transparent"
                                           RadiusX="2"
                                           RadiusY="2"
                                           Stroke="{DynamicResource Brushes.Outline}"
                                           StrokeThickness="1" />
                                <Rectangle x:Name="OuterCircleStateLayer"
                                           Margin="1"
                                           Fill="Transparent"
                                           RadiusX="2"
                                           RadiusY="2" />
                                <Viewbox x:Name="InnerCanvas"
                                         Width="16"
                                         Height="16">
                                    <Canvas Width="20" Height="20">
                                        <Path x:Name="InnerShape"
                                              Data="M3 10 L8 15 L17 5"
                                              Stroke="{DynamicResource Brushes.OnPrimary}"
                                              StrokeDashArray="24"
                                              StrokeDashOffset="24"
                                              StrokeThickness="2" />
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </BulletDecorator.Bullet>
                        <ContentPresenter Margin="4,0,0,0"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </BulletDecorator>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="ShowShape" Storyboard="{StaticResource ShowInnerShape}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard x:Name="HideShape" Storyboard="{StaticResource HideInnerShape}" />
                            </Trigger.ExitActions>
                            <Setter TargetName="OuterCircle" Property="StrokeThickness" Value="0" />
                            <Setter TargetName="OuterCircle" Property="Fill" Value="{DynamicResource Brushes.Primary}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterCircle" Property="Fill">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level4}" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterCircleStateLayer" Property="Fill">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level4}" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterCircleStateLayer" Property="Fill">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.InverseOverlay.Level4}" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterCircle" Property="Fill">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level2}" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>
                        <!--<MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="OuterCircle" Property="Fill" Value="{DynamicResource Brushes.Outline}" />
                        </MultiTrigger>-->
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="ToggleSwitchCheckBox" TargetType="{x:Type CheckBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brushes.OnSurface}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="InnerCircleToRight">
                            <DoubleAnimation Storyboard.TargetName="InnerCircleTransform"
                                             Storyboard.TargetProperty="X"
                                             To="22"
                                             Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation Storyboard.TargetName="InnerCircle"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="Black"
                                            Duration="0:0:0.2" />
                        </Storyboard>
                        <Storyboard x:Key="InnerCircleToLeft">
                            <DoubleAnimation Storyboard.TargetName="InnerCircleTransform"
                                             Storyboard.TargetProperty="X"
                                             To="0"
                                             Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation Storyboard.TargetName="InnerCircle"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="#948F99"
                                            Duration="0:0:0.2" />
                        </Storyboard>
                    </ControlTemplate.Resources>

                    <BulletDecorator Background="Transparent">
                        <BulletDecorator.Bullet>
                            <Border x:Name="OuterCircle"
                                    Width="40"
                                    Height="20"
                                    Margin="0,0,4,0"
                                    Padding="3"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource Brushes.Outline}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid x:Name="InnerLayer">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="InnerCircleTransform" X="0" />
                                    </Grid.RenderTransform>
                                    <Rectangle x:Name="InnerCircle"
                                               Width="12"
                                               Height="12"
                                               HorizontalAlignment="Left"
                                               Fill="{DynamicResource Brushes.Outline}"
                                               RadiusX="8"
                                               RadiusY="8" />
                                    <Rectangle x:Name="InnerCircleStateLayer"
                                               Width="12"
                                               Height="12"
                                               HorizontalAlignment="Left"
                                               Fill="Transparent"
                                               RadiusX="8"
                                               RadiusY="8" />
                                </Grid>
                            </Border>
                        </BulletDecorator.Bullet>
                        <ContentPresenter Margin="4,0,0,0"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </BulletDecorator>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource InnerCircleToRight}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource InnerCircleToLeft}" />
                            </Trigger.ExitActions>
                            <Setter TargetName="OuterCircle" Property="BorderThickness" Value="0" />
                            <Setter TargetName="InnerCircleStateLayer" Property="Fill" Value="Transparent" />
                            <Setter TargetName="OuterCircle" Property="Background" Value="{DynamicResource Brushes.Primary}" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="InnerCircleStateLayer" Property="Fill">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level4}" />
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <!--<Setter TargetName="OuterCircle" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{DynamicResource Colors.Overlay.Level2}" />
                                </Setter.Value>
                            </Setter>-->
                            <Setter Property="Opacity" Value="0.5"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>