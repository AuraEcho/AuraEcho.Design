    <!-- 主色（Primary）：应用的核心品牌色，用于主要按钮、强调元素 -->
    <SolidColorBrush x:Key="Brushes.Primary" Color="#C680FF" />
    <!-- 主色上的内容（文字/图标），保证在主色背景上可读 -->
    <SolidColorBrush x:Key="Brushes.OnPrimary" Color="{StaticResource Colors.Primary-0}" />
    <!-- 主色容器：用于卡片、选中状态背景，比 Primary 更柔和 -->
    <SolidColorBrush x:Key="Brushes.PrimaryContainer" Color="{StaticResource Colors.Primary-30}" />
    <!-- 主色容器上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnPrimaryContainer" Color="{StaticResource Colors.Primary-90}" />

    <!-- 次要色（Secondary）：用于辅助强调，不抢主视觉 -->
    <SolidColorBrush x:Key="Brushes.Secondary" Color="{StaticResource Colors.Secondary-80}" />
    <!-- 次要色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSecondary" Color="{StaticResource Colors.Secondary-20}" />
    <!-- 次要色容器 -->
    <SolidColorBrush x:Key="Brushes.SecondaryContainer" Color="{StaticResource Colors.Secondary-30}" />
    <!-- 次要色容器上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSecondaryContainer" Color="{StaticResource Colors.Secondary-90}" />

    <!-- 第三色（Tertiary）：用于装饰性强调、区分不同模块 -->
    <SolidColorBrush x:Key="Brushes.Tertiary" Color="{StaticResource Colors.Tertiary-80}" />
    <!-- 第三色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiary" Color="{StaticResource Colors.Tertiary-20}" />
    <!-- 第三色容器 -->
    <SolidColorBrush x:Key="Brushes.TertiaryContainer" Color="{StaticResource Colors.Tertiary-30}" />
    <!-- 第三色容器上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiaryContainer" Color="{StaticResource Colors.Tertiary-90}" />

    <!-- 错误色：用于错误提示、警告 -->
    <SolidColorBrush x:Key="Brushes.Error" Color="{StaticResource Colors.Error-80}" />
    <!-- 错误色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnError" Color="{StaticResource Colors.Error-20}" />
    <!-- 错误容器：用于错误提示框背景 -->
    <SolidColorBrush x:Key="Brushes.ErrorContainer" Color="{StaticResource Colors.Error-30}" />
    <!-- 错误容器上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnErrorContainer" Color="{StaticResource Colors.Error-90}" />

    <!-- 背景色：应用最底层背景 -->
    <!--<SolidColorBrush x:Key="Brushes.Background" Color="{StaticResource Colors.Neutral-10}" />-->
    <!-- 背景上的内容 -->
    <!--<SolidColorBrush x:Key="Brushes.OnBackground" Color="{StaticResource Colors.Neutral-90}" />-->
    <!-- 表面色：卡片、页面主体背景 -->
    <!--<SolidColorBrush x:Key="Brushes.Surface" Color="{StaticResource Colors.White-10}" />-->
    <!-- 表面上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSurface" Color="{StaticResource Colors.Neutral-90}" />

    <!-- 表面变体：用于分区背景（例如 List、Panel） -->
    <!--<SolidColorBrush x:Key="Brushes.SurfaceVariant" Color="{StaticResource Colors.Neutral-variant-30}" />-->
    <!-- 表面变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSurfaceVariant" Color="#8C8C8C" />
    <!-- 描边颜色：用于边框、分割线 -->
    <SolidColorBrush x:Key="Brushes.Outline" Color="{StaticResource Colors.Neutral-variant-50}" />
    <!-- 次级描边：更弱的边框/分割线 -->
    <SolidColorBrush x:Key="Brushes.OutlineVariant" Color="#3b3b3b" />
    <SolidColorBrush x:Key="Brushes.OutlineInner" Color="{StaticResource Colors.Overlay.Level3}" />
    <SolidColorBrush x:Key="Brushes.OutlineShadow" Color="{StaticResource Colors.Black-35}" />


    <!-- Dim 表面：更暗的表面（层级较低） -->
    <SolidColorBrush x:Key="Brushes.SurfaceDim" Color="{StaticResource Colors.Neutral-10}" />
    <!-- Bright 表面：更亮的表面（用于突出） -->
    <SolidColorBrush x:Key="Brushes.SurfaceBright" Color="{StaticResource Colors.Neutral-25}" />
    <!-- 最低层容器 -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerLowest" Color="{StaticResource Colors.Neutral-0}" />
    <!-- 低层容器 -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerLow" Color="{StaticResource Colors.Neutral-5}" />
    <!-- 标准容器 -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainer" Color="{StaticResource Colors.Overlay.Level3}" />
    <!-- 高层容器 -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerHigh" Color="#2C2C2C" />
    <!-- 最高层容器（浮层、弹窗等） -->
    <SolidColorBrush x:Key="Brushes.SurfaceContainerHighest" Color="#202020" />
    <!-- 弹窗遮罩 -->
    <SolidColorBrush x:Key="Brushes.Scrim" Color="{StaticResource Colors.Black-35}" />
    <!-- 阴影 -->
    <SolidColorBrush x:Key="Brushes.Shadow" Color="{StaticResource Colors.Neutral-20}" />

    <!-- 反转表面：用于深色区域（如底部栏） -->
    <SolidColorBrush x:Key="Brushes.InverseSurface" Color="{StaticResource Colors.Neutral-90}" />
    <!-- 反转表面上的内容 -->
    <SolidColorBrush x:Key="Brushes.InverseOnSurface" Color="{StaticResource Colors.Neutral-20}" />
    <!-- 反转主色：在深色背景上使用的主色 -->
    <SolidColorBrush x:Key="Brushes.InversePrimary" Color="{StaticResource Colors.Primary-40}" />

    <!-- 固定主色 -->
    <SolidColorBrush x:Key="Brushes.PrimaryFixed" Color="{StaticResource Colors.Primary-90}" />
    <!-- 固定主色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnPrimaryFixed" Color="{StaticResource Colors.Primary-10}" />
    <!-- 固定主色（较暗） -->
    <SolidColorBrush x:Key="Brushes.PrimaryFixedDim" Color="{StaticResource Colors.Primary-80}" />
    <!-- 固定主色变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnPrimaryFixedVariant" Color="{StaticResource Colors.Primary-30}" />

    <!-- 固定次要色 -->
    <SolidColorBrush x:Key="Brushes.SecondaryFixed" Color="{StaticResource Colors.Secondary-90}" />
    <!-- 固定次要色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSecondaryFixed" Color="{StaticResource Colors.Secondary-10}" />
    <!-- 固定次要色（较暗） -->
    <SolidColorBrush x:Key="Brushes.SecondaryFixedDim" Color="{StaticResource Colors.Secondary-80}" />
    <!-- 固定次要色变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnSecondaryFixedVariant" Color="{StaticResource Colors.Secondary-30}" />

    <!-- 固定第三色 -->
    <SolidColorBrush x:Key="Brushes.TertiaryFixed" Color="{StaticResource Colors.Tertiary-90}" />
    <!-- 固定第三色上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiaryFixed" Color="{StaticResource Colors.Tertiary-10}" />
    <!-- 固定第三色（较暗） -->
    <SolidColorBrush x:Key="Brushes.TertiaryFixedDim" Color="{StaticResource Colors.Tertiary-80}" />
    <!-- 固定第三色变体上的内容 -->
    <SolidColorBrush x:Key="Brushes.OnTertiaryFixedVariant" Color="{StaticResource Colors.Tertiary-30}" />

    <SolidColorBrush x:Key="Brushes.Success" Color="#00DE07" />
    <SolidColorBrush x:Key="Brushes.Warning" Color="#FF9D00" />

    <!--#region Special-->
    <!-- 背景 -->
    <DrawingBrush x:Key="Brushes.Special.Background">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Geometry="M0,0 H1 V1 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0, 0" EndPoint="0, 1">
                            <GradientStop Offset="0" Color="#FF9A3BFF" />
                            <GradientStop Offset="1" Color="#00000000" />
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H1 V1 H0 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush Center=".5, 0" GradientOrigin=".5, 0" RadiusX="1" RadiusY="1">
                            <GradientStop Offset="0" Color="#FF000000" />
                            <GradientStop Offset="1" Color="#00000000" />
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H1 V1 H0 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush Center=".5, 0.2" GradientOrigin=".5, 0.2" RadiusX="0.5" RadiusY="0.8">
                            <GradientStop Offset="0" Color="#FF4B2B8C" />
                            <GradientStop Offset="1" Color="#00000000" />
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <!-- 高光边框 -->
    <DrawingBrush x:Key="Brushes.Special.HighlightOutline">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#33FFFFFF" Geometry="M0,0 H1 V1 H0 Z" />
                <GeometryDrawing Geometry="M0,0 H1 V1 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0.7, 0" EndPoint="0.5, 0.4">
                            <GradientStop Offset="0" Color="#99FFFFFF" />
                            <GradientStop Offset="1" Color="#00FFFFFF" />
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <SolidColorBrush x:Key="Brushes.Special.OnSpecialBackground" Color="{StaticResource Colors.InverseOverlay.Level5}" />
    <!-- 面板上的渐变文本 -->
    <LinearGradientBrush x:Key="Brushes.Special.OnSurfaceLinear" StartPoint="0, 0" EndPoint="0, 1">
        <GradientStop Offset="0.2" Color="White" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Brushes.Special.FloatingBackground" Color="#150b26" />
    <!--#endregion-->

    <!-- 骨架屏 -->
    <Color x:Key="Colors.SkeletonShimmer">#40FFFFFF</Color>
    <SolidColorBrush x:Key="Brushes.SkeletonBase" Color="{StaticResource Colors.Neutral-20}" />
</ResourceDictionary>