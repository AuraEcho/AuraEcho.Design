<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:loc="clr-namespace:AuraEcho.Design.Localization">

    <!--  输入框统一右键编辑菜单：撤销 / 剪切 / 复制 / 粘贴 / 删除 / 全选  -->
    <!--  文字绑定 Design 本地化中枢 DesignLocalization，语言切换时由宿主统一刷新  -->
    <!--  x:Shared="False" 保证每个输入框获得独立实例（ContextMenu 只能有一个逻辑父级）  -->
    <ContextMenu x:Key="TextEditingContextMenu"
                 x:Shared="False"
                 Placement="MousePoint">
        <MenuItem Command="ApplicationCommands.Undo"
                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="{Binding Source={x:Static loc:DesignLocalization.Current}, Path=Strings.TextMenu_Undo}">
            <MenuItem.Icon>
                <Viewbox>
                    <Canvas Width="24" Height="24">
                        <Path Data="M12.5,8C9.85,8 7.45,9 5.6,10.6L2,7V16H11L7.38,12.38C8.77,11.22 10.54,10.5 12.5,10.5C16.04,10.5 19.05,12.81 20.1,16L22.47,15.22C21.08,11.03 17.15,8 12.5,8Z" Fill="{DynamicResource Brushes.OnSurface}" />
                    </Canvas>
                </Viewbox>
            </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Command="ApplicationCommands.Cut"
                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="{Binding Source={x:Static loc:DesignLocalization.Current}, Path=Strings.TextMenu_Cut}">
            <MenuItem.Icon>
                <Viewbox>
                    <Canvas Width="24" Height="24">
                        <Path Data="M19,3L13,9L15,11L22,4V3M12,12.5A0.5,0.5 0 0,1 11.5,12A0.5,0.5 0 0,1 12,11.5A0.5,0.5 0 0,1 12.5,12A0.5,0.5 0 0,1 12,12.5M6,20A2,2 0 0,1 4,18C4,16.89 4.9,16 6,16A2,2 0 0,1 8,18C8,19.11 7.1,20 6,20M6,8A2,2 0 0,1 4,6C4,4.89 4.9,4 6,4A2,2 0 0,1 8,6C8,7.11 7.1,8 6,8M9.64,7.64C9.87,7.14 10,6.59 10,6A4,4 0 0,0 6,2A4,4 0 0,0 2,6A4,4 0 0,0 6,10C6.59,10 7.14,9.87 7.64,9.64L10,12L7.64,14.36C7.14,14.13 6.59,14 6,14A4,4 0 0,0 2,18A4,4 0 0,0 6,22A4,4 0 0,0 10,18C10,17.41 9.87,16.86 9.64,16.36L12,14L19,21H22V20L9.64,7.64Z" Fill="{DynamicResource Brushes.OnSurface}" />
                    </Canvas>
                </Viewbox>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="ApplicationCommands.Copy"
                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="{Binding Source={x:Static loc:DesignLocalization.Current}, Path=Strings.TextMenu_Copy}">
            <MenuItem.Icon>
                <Viewbox>
                    <Canvas Width="24" Height="24">
                        <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Fill="{DynamicResource Brushes.OnSurface}" />
                    </Canvas>
                </Viewbox>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="ApplicationCommands.Paste"
                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="{Binding Source={x:Static loc:DesignLocalization.Current}, Path=Strings.TextMenu_Paste}">
            <MenuItem.Icon>
                <Viewbox>
                    <Canvas Width="24" Height="24">
                        <Path Data="M19,20H5V4H7V7H17V4H19M12,2A1,1 0 0,1 13,3A1,1 0 0,1 12,4A1,1 0 0,1 11,3A1,1 0 0,1 12,2M19,2H14.82C14.4,0.84 13.3,0 12,0C10.7,0 9.6,0.84 9.18,2H5A2,2 0 0,0 3,4V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V4A2,2 0 0,0 19,2Z" Fill="{DynamicResource Brushes.OnSurface}" />
                    </Canvas>
                </Viewbox>
            </MenuItem.Icon>
        </MenuItem>
        <MenuItem Command="EditingCommands.Delete"
                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="{Binding Source={x:Static loc:DesignLocalization.Current}, Path=Strings.TextMenu_Delete}">
            <MenuItem.Icon>
                <Viewbox>
                    <Canvas Width="24" Height="24">
                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="{DynamicResource Brushes.OnSurface}" />
                    </Canvas>
                </Viewbox>
            </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Command="ApplicationCommands.SelectAll"
                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                  Header="{Binding Source={x:Static loc:DesignLocalization.Current}, Path=Strings.TextMenu_SelectAll}">
            <MenuItem.Icon>
                <Viewbox>
                    <Canvas Width="24" Height="24">
                        <Path Data="M3,5H5V3C3.9,3 3,3.9 3,5M5,21V19H3C3,20.1 3.9,21 5,21M3,9H5V7H3V9M13,3H11V5H13V3M19,3V5H21C21,3.9 20.1,3 19,3M13,19H11V21H13V19M3,17H5V15H3V17M9,3H7V5H9V3M9,21H7V19H9V21M19,17H21V15H19V17M19,9H21V7H19V9M19,13H21V11H19V13M19,21C20.1,21 21,20.1 21,19H19V21M15,3V5H17V3H15M15,21H17V19H15V21M7,17H17V7H7V17M9,9H15V15H9V9Z" Fill="{DynamicResource Brushes.OnSurface}" />
                    </Canvas>
                </Viewbox>
            </MenuItem.Icon>
        </MenuItem>
    </ContextMenu>

</ResourceDictionary>
