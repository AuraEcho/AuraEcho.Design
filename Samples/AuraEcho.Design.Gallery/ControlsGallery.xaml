<UserControl x:Class="AuraEcho.Design.Gallery.ControlsGallery"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:ui="http://ui.auraecho.com/"
             d:DesignHeight="1629.167"
             d:DesignWidth="914"
             d:Height="450"
             d:Width="800"
             Background="{DynamicResource Brushes.SurfaceContainerLowest}"
             mc:Ignorable="d">
    <Grid>
        <Grid x:Name="DarkAppTitleContainer"
              Grid.Row="0"
              Height="36"
              VerticalAlignment="Top"
              Background="Transparent"
              ColumnDefinitions="Auto, *, Auto"
              UseLayoutRounding="True">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseLeftButtonDown">
                    <i:CallMethodAction MethodName="DragMove" TargetObject="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Margin="15,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource Brushes.OnSurface}"
                           Text="AuraEcho.Controls" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">

                <Button Width="47"
                        FontSize="14"
                        IsTabStop="False"
                        Style="{DynamicResource WindowButtonStyle}"
                        ToolTip="最小化"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <i:ChangePropertyAction PropertyName="WindowState"
                                                    TargetObject="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                                                    Value="Minimized" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <Canvas Width="16" Height="16">
                        <Rectangle Canvas.Left="2.0"
                                   Canvas.Top="8.0"
                                   Width="12.0"
                                   Height="1.0"
                                   Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}"
                                   RadiusX="0.5"
                                   RadiusY="0.5" />
                    </Canvas>
                </Button>
                <Button Width="47"
                        Click="MaxWin_MouseClick"
                        FontSize="14"
                        IsTabStop="False"
                        Style="{DynamicResource WindowButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Grid>
                        <i:Interaction.Triggers>
                            <i:DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="{x:Static WindowState.Normal}">
                                <i:ChangePropertyAction PropertyName="Visibility"
                                                        TargetName="MaxWindowIcon"
                                                        Value="{x:Static Visibility.Visible}" />
                                <i:ChangePropertyAction PropertyName="Visibility"
                                                        TargetName="RestoreWindowIcon"
                                                        Value="{x:Static Visibility.Hidden}" />
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}"
                                           Comparison="NotEqual"
                                           Value="{x:Static WindowState.Normal}">
                                <i:ChangePropertyAction PropertyName="Visibility"
                                                        TargetName="MaxWindowIcon"
                                                        Value="{x:Static Visibility.Hidden}" />
                                <i:ChangePropertyAction PropertyName="Visibility"
                                                        TargetName="RestoreWindowIcon"
                                                        Value="{x:Static Visibility.Visible}" />
                            </i:DataTrigger>
                        </i:Interaction.Triggers>
                        <Viewbox x:Name="MaxWindowIcon"
                                 Width="10"
                                 Height="10"
                                 Visibility="Hidden">
                            <Canvas Width="10" Height="10">
                                <Path Data="M 10 1 C 10 0.45 9.55 0 9 0 H 1 C 0.45 0 0 0.45 0 1 V 9 C 0 9.55 0.45 10 1 10 H 9 C 9.55 10 10 9.55 10 9 V 1 Z M 1 1 H 9 V 9 H 1 V 1 Z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}" />
                            </Canvas>
                        </Viewbox>

                        <Viewbox x:Name="RestoreWindowIcon"
                                 Width="16"
                                 Height="16">
                            <Canvas Width="16.0" Height="16.0">
                                <Rectangle Canvas.Left="2.5"
                                           Canvas.Top="4.5"
                                           Width="9.0"
                                           Height="9.0"
                                           RadiusX="0.5"
                                           RadiusY="0.5"
                                           Stroke="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}"
                                           StrokeDashCap="Flat"
                                           StrokeThickness="1.0" />
                                <Path Stroke="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}"
                                      StrokeDashCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeThickness="1.0">
                                    <Path.Data>
                                        <PathGeometry Figures="M 5.5 4.48421 L 5.5 3 C 5.5 2.72386 5.72386 2.5 6 2.5 H 13 C 13.2761 2.5 13.5 2.72386 13.5 3 V 10 C 13.5 10.2761 13.2761 10.5 13 10.5 H 11.5102" FillRule="Nonzero" />
                                    </Path.Data>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Button>
                <Button Width="47"
                        BorderThickness="0"
                        Click="CloseWindowButton_Click"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        IsTabStop="False"
                        Style="{DynamicResource WindowButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Canvas Width="16" Height="16">
                        <Path Data="M 3.14645 3.14645 C 3.34171 2.95118 3.65829 2.95118 3.85355 3.14645 L 8 7.293 L 12.1464 3.14645 C 12.32 2.97288 12.5894 2.9536 12.7843 3.08859 L 12.8536 3.14645 C 13.0488 3.34171 13.0488 3.65829 12.8536 3.85355 L 8.707 8 L 12.8536 12.1464 C 13.0271 12.32 13.0464 12.5894 12.9114 12.7843 L 12.8536 12.8536 C 12.6583 13.0488 12.3417 13.0488 12.1464 12.8536 L 8 8.707 L 3.85355 12.8536 C 3.67999 13.0271 3.41056 13.0464 3.21569 12.9114 L 3.14645 12.8536 C 2.95118 12.6583 2.95118 12.3417 3.14645 12.1464 L 7.293 8 L 3.14645 3.85355 C 2.97288 3.67999 2.9536 3.41056 3.08859 3.21569 L 3.14645 3.14645 Z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}" />
                    </Canvas>
                </Button>
            </StackPanel>
        </Grid>
        <ScrollViewer Margin="0,36,0,0">
            <Grid RowDefinitions="Auto, *">
                <!-- Menu -->
                <Menu Background="Transparent"
                      ContextMenuService.Placement="Bottom"
                      ContextMenuService.PlacementTarget="{Binding RelativeSource={RelativeSource self}}"
                      Foreground="White">
                    <MenuItem Header="File1" />
                    <MenuItem Header="Window">
                        <MenuItem Header="AAA" />
                        <MenuItem Header="BBB">
                            <MenuItem Header="B1" />
                            <MenuItem Header="B2" />
                            <Separator />
                            <MenuItem Header="B4" />
                        </MenuItem>
                        <MenuItem Header="CCC" />
                    </MenuItem>
                    <MenuItem Header="Help">
                        <MenuItem Header="C1" />
                        <MenuItem Header="C2" />
                    </MenuItem>
                </Menu>
                <StackPanel Grid.Row="1">
                    <!-- Buttons -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="Buttons" />
                            <WrapPanel>
                                <Button Margin="0,0,8,0"
                                        Padding="24,8"
                                        Content="Primary"
                                        Style="{DynamicResource PrimaryButtonStyle}" />
                                <Button Margin="0,0,8,0"
                                        Padding="24,8"
                                        ui:ControlHelper.BusyContent="Loading"
                                        ui:ControlHelper.IsBusy="True"
                                        Content="Primary Loading"
                                        Style="{DynamicResource PrimaryButtonStyle}" />
                                <Button Margin="0,0,8,0"
                                        Padding="24,8"
                                        Content="Primary Disabled"
                                        IsEnabled="False"
                                        Style="{DynamicResource PrimaryButtonStyle}" />
                                <Button Margin="0,0,8,0"
                                        Padding="24,8"
                                        Content="默认" />
                                <Button Margin="0,0,8,0"
                                        Padding="24,8"
                                        Content="Default Disabled"
                                        IsEnabled="False" />
                                <Button Margin="0,0,8,0"
                                        Padding="8"
                                        Style="{DynamicResource IconButtonStyle}">
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="16"
                                                Height="16"
                                                UseLayoutRounding="False">
                                            <Path Data="M 1.5 4.5 V 2.5 H 6.5 L 8.5 4.5 H 14.5 V 13.5 H 1.5 V 4.5 Z"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}"
                                                  StrokeDashCap="Flat"
                                                  StrokeLineJoin="Round"
                                                  StrokeThickness="1" />
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button Margin="0,0,8,0"
                                        Padding="8"
                                        IsEnabled="False"
                                        Style="{DynamicResource IconButtonStyle}">
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="16"
                                                Height="16"
                                                UseLayoutRounding="False">
                                            <Path Data="M 1.5 4.5 V 2.5 H 6.5 L 8.5 4.5 H 14.5 V 13.5 H 1.5 V 4.5 Z"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}"
                                                  StrokeDashCap="Flat"
                                                  StrokeLineJoin="Round"
                                                  StrokeThickness="1" />
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- CheckBoxs -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="CheckBoxs" />
                            <WrapPanel>
                                <CheckBox Content="Option 1" />
                                <CheckBox Content="Option 2"
                                          IsChecked="True"
                                          IsEnabled="False" />
                                <CheckBox Content="Option 2" IsEnabled="False" />
                                <CheckBox Content="Option 3" Style="{DynamicResource ToggleSwitchCheckBox}" />
                                <CheckBox Content="Option 4"
                                          IsEnabled="False"
                                          Style="{DynamicResource ToggleSwitchCheckBox}" />
                                <CheckBox Content="Option 4"
                                          IsChecked="True"
                                          IsEnabled="False"
                                          Style="{DynamicResource ToggleSwitchCheckBox}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ComboBoxs -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="ComboBoxs" />
                            <WrapPanel>
                                <ComboBox Width="120"
                                          Margin="0,0,8,0"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Option 1" />
                                    <ComboBoxItem Content="Option 2" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                    <ComboBoxItem Content="Option 3" />
                                </ComboBox>
                                <ComboBox Width="120"
                                          Margin="0,0,8,0"
                                          IsEnabled="False"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Option 1" />
                                </ComboBox>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ContextMenu -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="ContextMenu" />
                            <Button x:Name="ContextMenuButton"
                                    Padding="24,8"
                                    HorizontalAlignment="Left"
                                    Content="ContextMenu">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="PrimaryButtonContextMenu"
                                                 Placement="Top"
                                                 PlacementTarget="{x:Reference ContextMenuButton}">
                                        <MenuItem Header="AAAA">
                                            <MenuItem.Icon>
                                                <Viewbox>
                                                    <Canvas Width="16" Height="16">
                                                        <Path Data="M 3.14645 3.14645 C 3.34171 2.95118 3.65829 2.95118 3.85355 3.14645 L 8 7.293 L 12.1464 3.14645 C 12.32 2.97288 12.5894 2.9536 12.7843 3.08859 L 12.8536 3.14645 C 13.0488 3.34171 13.0488 3.65829 12.8536 3.85355 L 8.707 8 L 12.8536 12.1464 C 13.0271 12.32 13.0464 12.5894 12.9114 12.7843 L 12.8536 12.8536 C 12.6583 13.0488 12.3417 13.0488 12.1464 12.8536 L 8 8.707 L 3.85355 12.8536 C 3.67999 13.0271 3.41056 13.0464 3.21569 12.9114 L 3.14645 12.8536 C 2.95118 12.6583 2.95118 12.3417 3.14645 12.1464 L 7.293 8 L 3.14645 3.85355 C 2.97288 3.67999 2.9536 3.41056 3.08859 3.21569 L 3.14645 3.14645 Z" Fill="{DynamicResource Brushes.OnSurface}" />
                                                    </Canvas>
                                                </Viewbox>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="BBBB">
                                            <MenuItem Header="B1">
                                                <MenuItem.Icon>
                                                    <Viewbox>
                                                        <Canvas Width="16" Height="16">
                                                            <Path Data="M 3.14645 3.14645 C 3.34171 2.95118 3.65829 2.95118 3.85355 3.14645 L 8 7.293 L 12.1464 3.14645 C 12.32 2.97288 12.5894 2.9536 12.7843 3.08859 L 12.8536 3.14645 C 13.0488 3.34171 13.0488 3.65829 12.8536 3.85355 L 8.707 8 L 12.8536 12.1464 C 13.0271 12.32 13.0464 12.5894 12.9114 12.7843 L 12.8536 12.8536 C 12.6583 13.0488 12.3417 13.0488 12.1464 12.8536 L 8 8.707 L 3.85355 12.8536 C 3.67999 13.0271 3.41056 13.0464 3.21569 12.9114 L 3.14645 12.8536 C 2.95118 12.6583 2.95118 12.3417 3.14645 12.1464 L 7.293 8 L 3.14645 3.85355 C 2.97288 3.67999 2.9536 3.41056 3.08859 3.21569 L 3.14645 3.14645 Z" Fill="{DynamicResource Brushes.OnSurface}" />
                                                        </Canvas>
                                                    </Viewbox>
                                                </MenuItem.Icon>
                                                <MenuItem Header="B2" />
                                                <MenuItem Header="B3" />
                                                <Separator />
                                                <MenuItem Header="B4" />
                                            </MenuItem>
                                        </MenuItem>
                                        <MenuItem Header="CCCC" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Hyperlink -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="Hyperlink" />
                            <TextBlock FontSize="14">
                                <Hyperlink>超链接文字</Hyperlink>
                            </TextBlock>
                            <TextBlock FontSize="14" IsEnabled="False">
                                <Hyperlink>超链接文字</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- InputBoxs -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="InputBoxs" />
                            <WrapPanel>
                                <TextBox Width="150"
                                         Height="40"
                                         Margin="8"
                                         Padding="12,8"
                                         ui:ControlHelper.PlaceHolder="浮动水印"
                                         ui:InputBoxHelper.FloatingBackground="#191919"
                                         FontSize="16"
                                         Style="{DynamicResource FloatingLabelTextBoxStyle}" />
                                <TextBox Width="150"
                                         Margin="8"
                                         Padding="12,8"
                                         ui:ControlHelper.PlaceHolder="浮动水印禁用"
                                         FontSize="14"
                                         IsEnabled="False"
                                         Style="{DynamicResource FloatingLabelTextBoxStyle}" />
                                <TextBox Width="150"
                                         Height="40"
                                         Margin="8"
                                         Padding="12,8"
                                         ui:ControlHelper.PlaceHolder="普通水印"
                                         FontSize="16" />
                                <TextBox Width="150"
                                         Margin="8"
                                         Padding="12,8"
                                         ui:ControlHelper.PlaceHolder="普通水印禁用"
                                         FontSize="14"
                                         IsEnabled="False" />
                                <PasswordBox Width="150"
                                             Height="40"
                                             Margin="8"
                                             Padding="12,8"
                                             ui:ControlHelper.PlaceHolder="密码"
                                             ui:InputBoxHelper.FloatingBackground="#191919"
                                             FontSize="16"
                                             Style="{DynamicResource FloatingLabelPasswordBoxStyle}" />
                                <PasswordBox Width="150"
                                             Margin="8"
                                             ui:ControlHelper.PlaceHolder="请输入密码"
                                             FontSize="16"
                                             IsEnabled="False"
                                             Style="{DynamicResource FloatingLabelPasswordBoxStyle}" />
                                <PasswordBox Width="150"
                                             Height="40"
                                             Margin="8"
                                             Padding="12,8"
                                             ui:ControlHelper.PlaceHolder="请输入密码"
                                             FontSize="16" />
                                <PasswordBox Width="150"
                                             Height="40"
                                             ui:ControlHelper.PlaceHolder="请输入密码"
                                             IsEnabled="False" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ProgressBars -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="ProgressBars" />
                            <ProgressBar Width="150"
                                         Height="3"
                                         Margin="4"
                                         HorizontalAlignment="Left"
                                         Maximum="100"
                                         Value="40" />
                            <ProgressBar Width="150"
                                         Height="3"
                                         Margin="4"
                                         HorizontalAlignment="Left"
                                         IsIndeterminate="True" />
                        </StackPanel>
                    </Border>
                    <!-- RadioButtons -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="RadioButtons" />
                            <StackPanel>

                                <RadioButton Margin="4" Content="Option1" />
                                <RadioButton Margin="4" Content="Option2" />
                            </StackPanel>
                            <StackPanel>
                                <RadioButton Margin="4"
                                             Content="Option3"
                                             IsChecked="True"
                                             IsEnabled="False" />
                                <RadioButton Margin="4"
                                             Content="Option Disabled"
                                             IsEnabled="False" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Sliders -->
                    <Border Margin="16,8"
                            Padding="16"
                            Background="{DynamicResource Brushes.SurfaceContainer}"
                            CornerRadius="4">
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brushes.OnSurface}"
                                       Text="Sliders" />
                            <Slider Width="200"
                                    Margin="4"
                                    HorizontalAlignment="Left"
                                    Maximum="10"
                                    Value="3" />
                            <Slider Width="200"
                                    Margin="4"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False"
                                    Maximum="10"
                                    Value="3" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
